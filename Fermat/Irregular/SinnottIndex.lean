import Fermat.Irregular.CircularUnitIndex
import Mathlib.NumberTheory.NumberField.DedekindZeta

/-!
# The regulator boundary in the circular-unit index formula

This file carries the exponent-`37` circular-unit certificate to the exact analytic boundary of
the Sinnott--Kummer index formula.

For a real family of units in a CM field, the index of the Hasse subgroup
`realUnits K ⊔ torsion K` cancels between Mathlib's regulator-index theorem and its CM regulator
formula.  Consequently,

`regOfFamily u / regulator K⁺ = 2 ^ rank K * realUnitRelIndex u`.

Combining this with the Dirichlet class-number formula gives an unconditional identity involving
the class number of `K⁺`.  At exponent `37`, the desired equality between the circular-unit index
and `h⁺` is then proved equivalent to the single residue evaluation

`dedekindZeta_residue K⁺ = regOfFamily circularUnitRegFamily37 / sqrt |discr K⁺|`.

The latter is precisely the missing cyclotomic zeta-factorization / circular-regulator theorem;
Mathlib currently contains neither that factorization nor Sinnott's index formula itself.
-/

open scoped NumberField

namespace Fermat.Irregular.SinnottIndex

noncomputable section

open NumberField NumberField.Units
open Fermat.Irregular.CircularUnitIndex

variable {K : Type*} [Field K]

/-- The index of the subgroup generated by `u` and all roots of unity, relative to the subgroup
generated by the units from the maximal real subfield and all roots of unity. -/
abbrev realUnitRelIndex {iota : Type*} (u : iota → (𝓞 K)ˣ) : ℕ :=
  (Subgroup.closure (Set.range u) ⊔ NumberField.Units.torsion K).relIndex
    (NumberField.IsCMField.realUnits K ⊔ NumberField.Units.torsion K)

section TotallyReal

variable {F : Type*} [Field F] [NumberField F] [NumberField.IsTotallyReal F]

/-- A root of unity in a totally real number field is `1` or `-1`. -/
theorem torsion_eq_one_or_neg_one_of_isTotallyReal (x : NumberField.Units.torsion F) :
    (x : (𝓞 F)ˣ) = 1 ∨ (x : (𝓞 F)ˣ) = -1 := by
  let φ : (𝓞 F)ˣ →* F :=
    (algebraMap (𝓞 F) F).toMonoidHom.comp (Units.coeHom (𝓞 F))
  have hxfin : IsOfFinOrder (φ x.1) :=
    MonoidHom.isOfFinOrder φ ((CommGroup.mem_torsion x.1).mp x.2)
  by_cases! hc : 2 < orderOf (φ x.1)
  · have hpos : 0 < NumberField.InfinitePlace.nrRealPlaces F := by
      rw [← NumberField.IsTotallyReal.finrank]
      exact Module.finrank_pos
    linarith [NumberField.InfinitePlace.IsPrimitiveRoot.nrRealPlaces_eq_zero_of_two_lt hc
      (IsPrimitiveRoot.orderOf (φ x.1))]
  · interval_cases hi : orderOf (φ x.1)
    · linarith [orderOf_pos_iff.2 hxfin]
    · left
      apply NumberField.Units.coe_injective
      simpa [φ] using orderOf_eq_one_iff.1 hi
    · right
      apply NumberField.Units.coe_injective
      rw [CharP.orderOf_eq_two_iff 0 (by decide)] at hi
      simpa [φ] using hi

/-- The only roots of unity in a totally real number field are `±1`. -/
theorem torsionOrder_eq_two_of_isTotallyReal : NumberField.Units.torsionOrder F = 2 := by
  classical
  refine Finset.card_eq_two.2
    ⟨1, ⟨-1, neg_one_mem_torsion⟩, by simp [← Subtype.coe_ne_coe],
      Finset.ext fun x ↦ ⟨fun _ ↦ ?_, fun _ ↦ Finset.mem_univ _⟩⟩
  rw [Finset.mem_insert, Finset.mem_singleton, ← Subtype.val_inj, ← Subtype.val_inj]
  exact torsion_eq_one_or_neg_one_of_isTotallyReal x

end TotallyReal

section CMField

variable [NumberField K] [NumberField.IsCMField K]

local notation3 "K⁺" => NumberField.maximalRealSubfield K

/-- The Hasse unit index cancels from the regulator of a real family.  This identifies its
regulator ratio over the maximal real subfield with its relative real-unit index, including the
infinite-index case. -/
theorem regOfFamily_div_regulator_maximalRealSubfield
    (u : Fin (NumberField.Units.rank K) → (𝓞 K)ˣ)
    (hu : ∀ i, u i ∈ NumberField.IsCMField.realUnits K) :
    NumberField.Units.regOfFamily u / NumberField.Units.regulator K⁺ =
      (2 : ℝ) ^ NumberField.Units.rank K * (realUnitRelIndex u : ℝ) := by
  let C := Subgroup.closure (Set.range u) ⊔ NumberField.Units.torsion K
  let R := NumberField.IsCMField.realUnits K ⊔ NumberField.Units.torsion K
  have hCR : C ≤ R := by
    apply sup_le
    · apply (Subgroup.closure_le _).mpr
      rintro _ ⟨i, rfl⟩
      exact (show NumberField.IsCMField.realUnits K ≤ R from le_sup_left) (hu i)
    · exact le_sup_right
  have htower : C.relIndex R * R.index = C.index :=
    Subgroup.relIndex_mul_index hCR
  have hR : R.index = NumberField.IsCMField.indexRealUnits K := rfl
  have hindex_ne : (NumberField.IsCMField.indexRealUnits K : ℝ) ≠ 0 := by
    rcases NumberField.IsCMField.indexRealUnits_eq_one_or_two (K := K) with h | h <;>
      simp [h]
  have htower_real : (C.index : ℝ) = (C.relIndex R : ℝ) *
      (NumberField.IsCMField.indexRealUnits K : ℝ) := by
    rw [← hR]
    exact_mod_cast htower.symm
  calc
    NumberField.Units.regOfFamily u / NumberField.Units.regulator K⁺ =
        (NumberField.Units.regOfFamily u / NumberField.Units.regulator K) *
          (NumberField.Units.regulator K / NumberField.Units.regulator K⁺) := by
      field_simp [NumberField.Units.regulator_ne_zero K]
    _ = (C.index : ℝ) *
        ((2 : ℝ) ^ NumberField.Units.rank K *
          (NumberField.IsCMField.indexRealUnits K : ℝ)⁻¹) := by
      rw [NumberField.Units.regOfFamily_div_regulator,
        NumberField.IsCMField.regulator_div_regulator_eq_two_pow_mul_indexRealUnits_inv]
    _ = (C.relIndex R : ℝ) * (NumberField.IsCMField.indexRealUnits K : ℝ) *
        ((2 : ℝ) ^ NumberField.Units.rank K *
          (NumberField.IsCMField.indexRealUnits K : ℝ)⁻¹) := by
      rw [htower_real]
    _ = (2 : ℝ) ^ NumberField.Units.rank K * (C.relIndex R : ℝ) := by
      field_simp [hindex_ne]

/-- Dirichlet's class-number formula after replacing the maximal-real-subfield regulator by a
real unit family's relative index.  This is the unconditional analytic identity immediately
before the cyclotomic residue evaluation used by Sinnott--Kummer. -/
theorem dedekindZeta_residue_mul_realUnitRelIndex
    (u : Fin (NumberField.Units.rank K) → (𝓞 K)ˣ)
    (hu : ∀ i, u i ∈ NumberField.IsCMField.realUnits K) :
    NumberField.dedekindZeta_residue K⁺ *
        ((2 : ℝ) ^ NumberField.Units.rank K * (realUnitRelIndex u : ℝ)) =
      (2 : ℝ) ^ NumberField.InfinitePlace.nrRealPlaces K⁺ *
        NumberField.Units.regOfFamily u * (NumberField.classNumber K⁺ : ℝ) /
        ((NumberField.Units.torsionOrder K⁺ : ℝ) *
          Real.sqrt |(NumberField.discr K⁺ : ℝ)|) := by
  rw [← regOfFamily_div_regulator_maximalRealSubfield u hu]
  rw [NumberField.dedekindZeta_residue_def,
    NumberField.IsTotallyReal.nrComplexPlaces_eq_zero, pow_zero, mul_one]
  field_simp [NumberField.Units.regulator_ne_zero]

end CMField

section ThirtySeven

variable [NumberField K] [IsCyclotomicExtension {37} ℚ K]

local notation3 "K⁺" => NumberField.maximalRealSubfield K

/-- The seventeen circular units transported to the canonical Dirichlet-rank index. -/
def circularUnitRegFamily37 {zeta : K} (hzeta : IsPrimitiveRoot zeta 37) :
    Fin (NumberField.Units.rank K) → (𝓞 K)ˣ :=
  circularUnit37 hzeta ∘ finCongr (cyclotomic37_unitRank (K := K))

/-- Reindexing does not change the set of exponent-`37` circular units. -/
theorem range_circularUnitRegFamily37 {zeta : K} (hzeta : IsPrimitiveRoot zeta 37) :
    Set.range (circularUnitRegFamily37 hzeta) = Set.range (circularUnit37 hzeta) :=
  EquivLike.range_comp (circularUnit37 hzeta)
    (finCongr (cyclotomic37_unitRank (K := K)))

local instance : NumberField.IsCMField K := cyclotomic37_isCMField (K := K)

/-- The maximal real subfield of a `37`th cyclotomic field has eighteen real places. -/
theorem nrRealPlaces_maximalRealSubfield37 :
    NumberField.InfinitePlace.nrRealPlaces K⁺ = 18 := by
  have hrank : NumberField.Units.rank K⁺ = 17 := by
    rw [NumberField.IsCMField.units_rank_eq_units_rank K,
      cyclotomic37_unitRank (K := K)]
  have hpos : 0 < NumberField.InfinitePlace.nrRealPlaces K⁺ := by
    rw [← NumberField.IsTotallyReal.finrank]
    exact Module.finrank_pos
  rw [NumberField.Units.rank,
    NumberField.InfinitePlace.card_eq_nrRealPlaces_add_nrComplexPlaces,
    NumberField.IsTotallyReal.nrComplexPlaces_eq_zero, add_zero] at hrank
  omega

/-- The circular-unit regulator over the maximal real regulator is `2^17` times the relative
real-unit index. -/
theorem circularUnit37_regulator_ratio {zeta : K} (hzeta : IsPrimitiveRoot zeta 37) :
    NumberField.Units.regOfFamily (circularUnitRegFamily37 hzeta) /
        NumberField.Units.regulator K⁺ =
      (2 : ℝ) ^ 17 * (realUnitRelIndex (circularUnit37 hzeta) : ℝ) := by
  have h := regOfFamily_div_regulator_maximalRealSubfield
    (u := circularUnitRegFamily37 hzeta)
    (fun i ↦ circularUnit37_mem_realUnits hzeta _)
  simpa only [realUnitRelIndex, range_circularUnitRegFamily37 hzeta,
    cyclotomic37_unitRank (K := K)] using h

/-- The exact class-number identity obtained from the circular-unit relative index and
Dirichlet's class-number formula, before evaluating the cyclotomic zeta residue. -/
theorem circularUnit37_residue_index_identity {zeta : K}
    (hzeta : IsPrimitiveRoot zeta 37) :
    NumberField.dedekindZeta_residue K⁺ *
        ((2 : ℝ) ^ 17 * (realUnitRelIndex (circularUnit37 hzeta) : ℝ)) =
      (2 : ℝ) ^ 18 * NumberField.Units.regOfFamily (circularUnitRegFamily37 hzeta) *
        (NumberField.classNumber K⁺ : ℝ) /
        ((NumberField.Units.torsionOrder K⁺ : ℝ) *
          Real.sqrt |(NumberField.discr K⁺ : ℝ)|) := by
  have h := dedekindZeta_residue_mul_realUnitRelIndex
    (u := circularUnitRegFamily37 hzeta)
    (fun i ↦ circularUnit37_mem_realUnits hzeta _)
  simpa only [realUnitRelIndex, range_circularUnitRegFamily37 hzeta,
    cyclotomic37_unitRank (K := K), nrRealPlaces_maximalRealSubfield37 (K := K)] using h

private theorem circularUnit37_realIndex_eq_classNumber_iff_residue_formula {zeta : K}
    (hzeta : IsPrimitiveRoot zeta 37) :
    realUnitRelIndex (circularUnit37 hzeta) = NumberField.classNumber K⁺ ↔
      NumberField.dedekindZeta_residue K⁺ * (2 : ℝ) ^ 17 =
        (2 : ℝ) ^ 18 * NumberField.Units.regOfFamily (circularUnitRegFamily37 hzeta) /
          ((NumberField.Units.torsionOrder K⁺ : ℝ) *
            Real.sqrt |(NumberField.discr K⁺ : ℝ)|) := by
  let I : ℕ := realUnitRelIndex (circularUnit37 hzeta)
  let hplus : ℕ := NumberField.classNumber K⁺
  let X : ℝ := NumberField.dedekindZeta_residue K⁺ * (2 : ℝ) ^ 17
  let Y : ℝ := (2 : ℝ) ^ 18 *
    NumberField.Units.regOfFamily (circularUnitRegFamily37 hzeta) /
      ((NumberField.Units.torsionOrder K⁺ : ℝ) *
        Real.sqrt |(NumberField.discr K⁺ : ℝ)|)
  have hbalance : X * (I : ℝ) = Y * (hplus : ℝ) := by
    dsimp only [X, Y, I, hplus]
    calc
      NumberField.dedekindZeta_residue K⁺ * (2 : ℝ) ^ 17 *
          (realUnitRelIndex (circularUnit37 hzeta) : ℝ) =
          NumberField.dedekindZeta_residue K⁺ *
            ((2 : ℝ) ^ 17 * (realUnitRelIndex (circularUnit37 hzeta) : ℝ)) := by
        ring
      _ = (2 : ℝ) ^ 18 * NumberField.Units.regOfFamily
            (circularUnitRegFamily37 hzeta) * (NumberField.classNumber K⁺ : ℝ) /
          ((NumberField.Units.torsionOrder K⁺ : ℝ) *
            Real.sqrt |(NumberField.discr K⁺ : ℝ)|) :=
        circularUnit37_residue_index_identity hzeta
      _ = ((2 : ℝ) ^ 18 * NumberField.Units.regOfFamily
            (circularUnitRegFamily37 hzeta) /
          ((NumberField.Units.torsionOrder K⁺ : ℝ) *
            Real.sqrt |(NumberField.discr K⁺ : ℝ)|)) *
          (NumberField.classNumber K⁺ : ℝ) := by
        ring
  have hX : X ≠ 0 := by
    apply mul_ne_zero (NumberField.dedekindZeta_residue_ne_zero _)
    positivity
  have hhplus : (hplus : ℝ) ≠ 0 := by
    exact_mod_cast NumberField.classNumber_ne_zero K⁺
  constructor
  · intro hI
    have hIreal : (I : ℝ) = (hplus : ℝ) := by exact_mod_cast hI
    have hXY : X = Y := mul_right_cancel₀ hhplus (by simpa [hIreal] using hbalance)
    simpa [X, Y] using hXY
  · intro hXY
    have hXY' : X = Y := by simpa [X, Y] using hXY
    have hIreal : (I : ℝ) = (hplus : ℝ) := by
      apply mul_left_cancel₀ hX
      calc
        X * (I : ℝ) = Y * (hplus : ℝ) := hbalance
        _ = X * (hplus : ℝ) := by rw [hXY']
    exact_mod_cast hIreal

/-- For exponent `37`, the desired Sinnott--Kummer circular-unit index formula is equivalent to
one explicit circular-regulator evaluation of the maximal real subfield's Dedekind-zeta residue.

This theorem does not assume either side.  It isolates exactly the analytic theorem still absent
from Mathlib. -/
theorem circularUnit37_realIndex_eq_classNumber_iff {zeta : K}
    (hzeta : IsPrimitiveRoot zeta 37) :
    realUnitRelIndex (circularUnit37 hzeta) = NumberField.classNumber K⁺ ↔
      NumberField.dedekindZeta_residue K⁺ =
        NumberField.Units.regOfFamily (circularUnitRegFamily37 hzeta) /
          Real.sqrt |(NumberField.discr K⁺ : ℝ)| := by
  rw [circularUnit37_realIndex_eq_classNumber_iff_residue_formula hzeta,
    torsionOrder_eq_two_of_isTotallyReal]
  constructor
  · intro h
    norm_num [div_eq_mul_inv] at h ⊢
    linarith
  · intro h
    norm_num [div_eq_mul_inv] at h ⊢
    linarith

end ThirtySeven

end

end Fermat.Irregular.SinnottIndex
