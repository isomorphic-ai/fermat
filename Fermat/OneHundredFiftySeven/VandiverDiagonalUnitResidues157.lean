import Fermat.OneHundredFiftySeven.CircularUnitResidues
import Fermat.OneHundredFiftySeven.VandiverDiagonalArithmetic157
import Mathlib.LinearAlgebra.Vandermonde

/-!
# Residue and Fourier certificates for Vandiver's diagonal units at 157

This module derives the residue matrix of Vandiver's seventy-seven
diagonal units from the already certified circular-unit matrix at
`q = 7537`.

The seventy-eight basic factors form the edges of the cyclic ordering
generated by `69` modulo sign.  Their positive integral weights are the
nontrivial even characters of that cycle.  Consequently the change of
basis is a scaled transpose Vandermonde matrix.  This avoids introducing a
second explicit `77 × 77` inverse: nonsingularity follows algebraically
from distinct Fourier nodes.
-/

namespace Fermat.OneHundredFiftySeven.VandiverDiagonalUnitResidues

open Fermat.OneHundredFiftySeven.VandiverDiagonalArithmetic
open Fermat.Irregular.CircularUnitFamily
open Fermat.Irregular.CircularUnitResidues
open Fermat.Irregular.CircularUnitResidues.Certificate

local instance : Fact (Nat.Prime 157) := ⟨by norm_num⟩
local instance : Fact (Nat.Prime 7537) := ⟨by norm_num⟩

set_option maxHeartbeats 0
set_option maxRecDepth 1000000

/-- The canonical circular-unit column corresponding to the real class
of `69^(j+1)`. -/
def cycleColumn157 (j : Fin 77) : Fin 77 :=
  let s := ((teichmullerRoot157 : ZMod 157) ^ (j.val + 1)).val
  let a := min s (157 - s)
  ⟨(a - 2) % 77, Nat.mod_lt _ (by norm_num)⟩

/-- The powers of `69` visit every nontrivial real class exactly once. -/
theorem cycleColumn157_bijective :
    Function.Bijective cycleColumn157 := by decide

noncomputable def cycleColumnEquiv157 : Fin 77 ≃ Fin 77 :=
  Equiv.ofBijective cycleColumn157 cycleColumn157_bijective

/-- The nontrivial even Fourier nodes `69^(-2n)`, `1 ≤ n ≤ 77`. -/
def vandermondeNode157 (i : Fin 77) : ZMod 157 :=
  (teichmullerRoot157 : ZMod 157) ^ (154 - 2 * i.val)

theorem vandermondeNode157_injective :
    Function.Injective vandermondeNode157 := by decide

/-- Column scale converting powers `0, ..., 76` to Vandiver's edge
coefficients. -/
def fourierScale157 (i : Fin 77) : ZMod 157 :=
  ((teichmullerRoot157 : ZMod 157) ^ (2 * (i.val + 1)) - 1) *
    (teichmullerRoot157 : ZMod 157) * vandermondeNode157 i

theorem fourierScale157_ne_zero (i : Fin 77) :
    fourierScale157 i ≠ 0 := by
  fin_cases i <;> decide

/-- The edge-to-diagonal change of basis. -/
def fourierChange157 : Matrix (Fin 77) (Fin 77) (ZMod 157) :=
  (Matrix.vandermonde vandermondeNode157).transpose *
    Matrix.diagonal fourierScale157

theorem fourierChange157_apply (row i : Fin 77) :
    fourierChange157 row i =
      vandermondeNode157 i ^ row.val * fourierScale157 i := by
  rw [fourierChange157, Matrix.mul_diagonal]
  rfl

/-- The scaled Fourier matrix is nonsingular. -/
theorem fourierChange157_det_ne_zero :
    fourierChange157.det ≠ 0 := by
  rw [fourierChange157, Matrix.det_mul, Matrix.det_transpose,
    Matrix.det_diagonal]
  exact mul_ne_zero
    (Matrix.det_vandermonde_ne_zero_iff.mpr
      vandermondeNode157_injective)
    (Finset.prod_ne_zero_iff.mpr
      (fun i _ ↦ fourierScale157_ne_zero i))

abbrev certificate157 : Certificate 157 7537 :=
  Fermat.OneHundredFiftySeven.CircularUnitResidues.certificate

/-- Extend the circular-unit cycle by the trivial class at positions
zero and seventy-eight. -/
def cycleClassSymbol157 (row : Fin 77) (ell : ℕ) : ZMod 157 :=
  if h : 1 ≤ ell ∧ ell ≤ 77 then
    Fermat.OneHundredFiftySeven.CircularUnitMatrix.matrix row
      (cycleColumn157 ⟨ell - 1, by omega⟩)
  else 0

/-- The symbol of the `j`th basic factor is the difference of adjacent
circular-unit symbols. -/
def basicEdgeSymbol157 (row : Fin 77) (j : Fin 78) : ZMod 157 :=
  cycleClassSymbol157 row (j.val + 1) -
    cycleClassSymbol157 row j.val

/-- Literal source exponent `226^j`. -/
def conjugateExponent157 (j : Fin 78) : ℕ :=
  teichmullerRoot157 ^ j.val

/-- Its small reduction modulo `157`. -/
def reducedConjugateExponent157 (j : Fin 78) : ℕ :=
  ((teichmullerRoot157 : ZMod 157) ^ j.val).val

theorem conjugateExponent157_modEq_reduced (j : Fin 78) :
    conjugateExponent157 j ≡ reducedConjugateExponent157 j [MOD 157] := by
  rw [← ZMod.natCast_eq_natCast_iff]
  simp [conjugateExponent157, reducedConjugateExponent157]

theorem pow_conjugateExponent157_eq_reduced {G : Type*} [Monoid G]
    (x : G) (hx : x ^ 157 = 1) (j : Fin 78) :
    x ^ conjugateExponent157 j = x ^ reducedConjugateExponent157 j :=
  pow_eq_pow_of_modEq (conjugateExponent157_modEq_reduced j) hx

/-- The literal 226-term geometric sum in the finite-field reduction. -/
def basicResidueGeomSum157 (row : Fin 77) (j : Fin 78) : ZMod 7537 :=
  let w := embeddingRoot (p := 157) certificate157.root row ^
    conjugateExponent157 j
  ∑ k ∈ Finset.range 226, w ^ k

/-- Reduction of the normalized basic factor. -/
def basicResidueValue157 (row : Fin 77) (j : Fin 78) : ZMod 7537 :=
  let w := embeddingRoot (p := 157) certificate157.root row ^
    conjugateExponent157 j
  w ^ 123 * basicResidueGeomSum157 row j

/-- Since `226 = 157 + 69`, the literal source sum reduces to length
sixty-nine at a 157th root. -/
theorem basicResidueGeomSum157_eq (row : Fin 77) (j : Fin 78) :
    basicResidueGeomSum157 row j =
      ∑ k ∈ Finset.range 69,
        (embeddingRoot (p := 157) certificate157.root row ^
          conjugateExponent157 j) ^ k := by
  let w : ZMod 7537 :=
    embeddingRoot (p := 157) certificate157.root row ^
      conjugateExponent157 j
  have hwroot : IsPrimitiveRoot w 157 := by
    apply (embeddingRoot_isPrimitive certificate157.hp2
      certificate157.root_isPrimitive row).pow_of_coprime
    exact (by norm_num : Nat.Coprime 226 157).pow_left j.val
  have hwne : w - 1 ≠ 0 :=
    sub_ne_zero.mpr (hwroot.ne_one (by norm_num))
  apply mul_left_cancel₀ (a := w - 1) hwne
  rw [show (w - 1) * basicResidueGeomSum157 row j = w ^ 226 - 1 by
    simpa [basicResidueGeomSum157, w] using (mul_geom_sum w 226)]
  rw [show (w - 1) *
      (∑ k ∈ Finset.range 69,
        (embeddingRoot (p := 157) certificate157.root row ^
          conjugateExponent157 j) ^ k) = w ^ 69 - 1 by
    simpa [w] using (mul_geom_sum w 69)]
  rw [show 226 = 157 + 69 by norm_num, pow_add, hwroot.pow_eq_one,
    one_mul]

/-- The base basic value at the real exponent `c+1`. -/
def baseBasicValue157 (c : Fin 78) : ZMod 7537 :=
  let w := certificate157.root ^ (c.val + 1)
  w ^ 123 * ∑ k ∈ Finset.range 69, w ^ k

/-- The first seventy-seven base symbols are the circular certificate's
column `a = 69`; the missing real class has symbol `78`. -/
def basicSymbolByRealExponent157 (c : Fin 78) : ZMod 157 :=
  if h : c.val < 77 then
    Fermat.OneHundredFiftySeven.CircularUnitMatrix.matrix
      ⟨c.val, h⟩ ⟨67, by norm_num⟩
  else 78

theorem normalizedUnitValue_column69_eq_base (c : Fin 77) :
    normalizedUnitValue (p := 157) certificate157.root c
        ⟨67, by norm_num⟩ =
      baseBasicValue157 ⟨c.val, by omega⟩ := by
  let w : ZMod 7537 := certificate157.root ^ (c.val + 1)
  have hwroot : IsPrimitiveRoot w 157 :=
    embeddingRoot_isPrimitive certificate157.hp2
      certificate157.root_isPrimitive c
  have hne : 1 - w ≠ 0 :=
    sub_ne_zero.mpr (Ne.symm (hwroot.ne_one (by norm_num)))
  simp only [normalizedUnitValue, embeddingRoot]
  change w ^
      canonicalNormalizationExponent (p := 157) (67 + 2) *
        (1 - w ^ (67 + 2)) / (1 - w) =
    w ^ 123 * ∑ k ∈ Finset.range 69, w ^ k
  have hnormal :
      canonicalNormalizationExponent (p := 157) (67 + 2) = 123 := by
    decide
  rw [hnormal]
  change w ^ 123 * (1 - w ^ 69) / (1 - w) =
    w ^ 123 * ∑ k ∈ Finset.range 69, w ^ k
  have hgeom :
      (1 - w ^ 69) / (1 - w) =
        ∑ k ∈ Finset.range 69, w ^ k := by
    apply (div_eq_iff hne).2
    calc
      1 - w ^ 69 = -((w - 1) *
          ∑ k ∈ Finset.range 69, w ^ k) := by rw [mul_geom_sum]; ring
      _ = (∑ k ∈ Finset.range 69, w ^ k) * (1 - w) := by ring
  rw [mul_div_assoc, hgeom]

/-- All seventy-eight base symbols are tied back to the existing
circular-unit entry certificate. -/
theorem baseBasicValue157_symbol (c : Fin 78) :
    baseBasicValue157 c ^ 48 =
      certificate157.root ^ (basicSymbolByRealExponent157 c).val := by
  by_cases hc : c.val < 77
  · let c' : Fin 77 := ⟨c.val, hc⟩
    have hentry := certificate157.entry_certificate c' ⟨67, by norm_num⟩
    rw [normalizedUnitValue_column69_eq_base c'] at hentry
    simpa [basicSymbolByRealExponent157, hc, c'] using hentry
  · have hc77 : c.val = 77 := by omega
    have hceq : c = ⟨77, by norm_num⟩ := Fin.ext hc77
    rw [hceq]
    decide

/-- Real class of `(row+1) * 69^j`, modulo sign. -/
def realEmbeddingIndex157 (row : Fin 77) (j : Fin 78) : Fin 78 :=
  let s := ((row.val + 1) * reducedConjugateExponent157 j) % 157
  let a := min s (157 - s)
  ⟨(a - 1) % 78, Nat.mod_lt _ (by norm_num)⟩

/-- The edge description agrees with the circular matrix in all
`77 × 78` positions. -/
theorem basicEdgeSymbol157_eq_base (row : Fin 77) (j : Fin 78) :
    basicEdgeSymbol157 row j =
      basicSymbolByRealExponent157 (realEmbeddingIndex157 row j) := by
  decide +revert

/-- The actual basic value depends only on its real exponent class. -/
theorem basicResidueValue157_eq_base (row : Fin 77) (j : Fin 78) :
    basicResidueValue157 row j =
      baseBasicValue157 (realEmbeddingIndex157 row j) := by
  rw [basicResidueValue157, basicResidueGeomSum157_eq]
  rw [pow_conjugateExponent157_eq_reduced _
    (embeddingRoot_isPrimitive certificate157.hp2
      certificate157.root_isPrimitive row).pow_eq_one]
  decide +revert

/-- Complete provenance of every basic-factor residue symbol. -/
theorem basicResidueValue157_symbol (row : Fin 77) (j : Fin 78) :
    basicResidueValue157 row j ^ 48 =
      certificate157.root ^ (basicEdgeSymbol157 row j).val := by
  rw [basicResidueValue157_eq_base,
    baseBasicValue157_symbol, basicEdgeSymbol157_eq_base]

end Fermat.OneHundredFiftySeven.VandiverDiagonalUnitResidues
