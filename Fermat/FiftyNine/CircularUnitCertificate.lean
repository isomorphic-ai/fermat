/-- Kernel-checked inverse certificate for all 784 matrix entries. -/
theorem matrix_mul_inverse : matrix * matrixInverse = 1 := by
  ext i j
  fin_cases i <;> fin_cases j <;> decide

/-- The package matrix is nonsingular over `ZMod 59`. -/
theorem matrix_det_ne_zero : matrix.det ≠ 0 := by
  intro hzero
  have hdet := congrArg Matrix.det matrix_mul_inverse
  rw [Matrix.det_mul, hzero, zero_mul, Matrix.det_one] at hdet
  exact (by decide : (0 : ZMod 59) ≠ 1) hdet

/-- Any actual residue-symbol functionals realizing this matrix certify a
unit-lattice index prime to `59`. -/
theorem not_dvd_card_quotient_span_of_evalMatrix_eq
    {M : Type*} [AddCommGroup M] (b : Module.Basis (Fin 28) ℤ M)
    (u : Fin 28 → M) (f : Fin 28 → M →ₗ[ℤ] ZMod 59)
    (heval : evalMatrix u f = matrix) :
    ¬ (59 ∣ Nat.card (M ⧸ Submodule.span ℤ (Set.range u))) := by
  apply not_dvd_card_quotient_span_of_eval_det_ne_zero b u f
  rw [heval]
  exact matrix_det_ne_zero

end Fermat.FiftyNine.CircularUnitCertificate
