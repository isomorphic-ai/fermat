import Fermat.FiveHundredEightySeven.CircularUnitResidues
import Fermat.FiveHundredEightySeven.VandiverDiagonalArithmetic587
import Mathlib.LinearAlgebra.Vandermonde

/-!
# Residue and Fourier certificates for Vandiver's diagonal units at 587

This module derives the residue matrix of Vandiver's 292
diagonal units from the already certified circular-unit matrix at
`q = 8219`.

The 293 basic factors form the edges of the cyclic ordering
generated by `72` modulo sign.  Their positive integral weights are the
nontrivial even characters of that cycle.  Consequently the change of
basis is a scaled transpose Vandermonde matrix.  This avoids introducing a
second explicit `292 × 292` inverse: nonsingularity follows algebraically
from distinct Fourier nodes.
-/

namespace Fermat.FiveHundredEightySeven.VandiverDiagonalUnitResidues

open Fermat.FiveHundredEightySeven.VandiverDiagonalArithmetic
open Fermat.FiveHundredEightySeven.CircularUnitCyclic
open Fermat.FiveHundredEightySeven.CircularUnitEntryCertificate
open Fermat.FiveHundredEightySeven.CircularUnitMatrix
open Fermat.Irregular.CircularUnitFamily
open Fermat.Irregular.CircularUnitResidues
open Fermat.Irregular.CircularUnitResidues.Certificate

local instance : Fact (Nat.Prime 587) := ⟨by norm_num⟩
local instance : Fact (Nat.Prime 8219) := ⟨by norm_num⟩

set_option maxHeartbeats 3000000
set_option maxRecDepth 1000000

/-- The canonical circular-unit column corresponding to the real class
of `72^(j+1)`. -/
def cycleColumn587 (j : Fin 292) : Fin 292 :=
  let s := ((teichmullerRoot587 : ZMod 587) ^ (j.val + 1)).val
  let a := min s (587 - s)
  ⟨(a - 2) % 292, Nat.mod_lt _ (by norm_num)⟩

/-- The powers of `72` visit every nontrivial real class exactly once. -/
theorem cycleColumn587_bijective :
    Function.Bijective cycleColumn587 := by decide

noncomputable def cycleColumnEquiv587 : Fin 292 ≃ Fin 292 :=
  Equiv.ofBijective cycleColumn587 cycleColumn587_bijective

/-- The nontrivial even Fourier nodes `72^(-2n)`, `1 ≤ n ≤ 292`. -/
def vandermondeNode587 (i : Fin 292) : ZMod 587 :=
  (teichmullerRoot587 : ZMod 587) ^ (584 - 2 * i.val)

theorem vandermondeNode587_injective :
    Function.Injective vandermondeNode587 := by decide

/-- Column scale converting powers `0, ..., 291` to Vandiver's edge
coefficients. -/
def fourierScale587 (i : Fin 292) : ZMod 587 :=
  ((teichmullerRoot587 : ZMod 587) ^ (2 * (i.val + 1)) - 1) *
    (teichmullerRoot587 : ZMod 587) * vandermondeNode587 i

theorem fourierScale587_ne_zero (i : Fin 292) :
    fourierScale587 i ≠ 0 := by
  fin_cases i <;> decide

/-- The edge-to-diagonal change of basis. -/
def fourierChange587 : Matrix (Fin 292) (Fin 292) (ZMod 587) :=
  (Matrix.vandermonde vandermondeNode587).transpose *
    Matrix.diagonal fourierScale587

theorem fourierChange587_apply (row i : Fin 292) :
    fourierChange587 row i =
      vandermondeNode587 i ^ row.val * fourierScale587 i := by
  rw [fourierChange587, Matrix.mul_diagonal]
  rfl

/-- The scaled Fourier matrix is nonsingular. -/
theorem fourierChange587_det_ne_zero :
    fourierChange587.det ≠ 0 := by
  rw [fourierChange587, Matrix.det_mul, Matrix.det_transpose,
    Matrix.det_diagonal]
  exact mul_ne_zero
    (Matrix.det_vandermonde_ne_zero_iff.mpr
      vandermondeNode587_injective)
    (Finset.prod_ne_zero_iff.mpr
      (fun i _ ↦ fourierScale587_ne_zero i))

abbrev certificate587 : Certificate 587 8219 :=
  Fermat.FiveHundredEightySeven.CircularUnitResidues.certificate

/-- Extend the circular-unit cycle by the trivial class at positions
zero and 293. -/
def cycleClassSymbol587 (row : Fin 292) (ell : ℕ) : ZMod 587 :=
  if h : 1 ≤ ell ∧ ell ≤ 292 then
    Fermat.FiveHundredEightySeven.CircularUnitMatrix.matrix row
      (cycleColumn587 ⟨ell - 1, by omega⟩)
  else 0

/-- The symbol of the `j`th basic factor is the difference of adjacent
circular-unit symbols. -/
def basicEdgeSymbol587 (row : Fin 292) (j : Fin 293) : ZMod 587 :=
  cycleClassSymbol587 row (j.val + 1) -
    cycleClassSymbol587 row j.val

/-- Literal source exponent `6529^j`. -/
def conjugateExponent587 (j : Fin 293) : ℕ :=
  teichmullerRoot587 ^ j.val

/-- Its small reduction modulo `587`. -/
def reducedConjugateExponent587 (j : Fin 293) : ℕ :=
  ((teichmullerRoot587 : ZMod 587) ^ j.val).val

theorem conjugateExponent587_modEq_reduced (j : Fin 293) :
    conjugateExponent587 j ≡ reducedConjugateExponent587 j [MOD 587] := by
  rw [← ZMod.natCast_eq_natCast_iff]
  simp [conjugateExponent587, reducedConjugateExponent587]

theorem pow_conjugateExponent587_eq_reduced {G : Type*} [Monoid G]
    (x : G) (hx : x ^ 587 = 1) (j : Fin 293) :
    x ^ conjugateExponent587 j = x ^ reducedConjugateExponent587 j :=
  pow_eq_pow_of_modEq (conjugateExponent587_modEq_reduced j) hx

/-- The literal 6529-term geometric sum in the finite-field reduction. -/
def basicResidueGeomSum587 (row : Fin 292) (j : Fin 293) : ZMod 8219 :=
  let w := embeddingRoot (p := 587) certificate587.root row ^
    conjugateExponent587 j
  ∑ k ∈ Finset.range 6529, w ^ k

/-- Reduction of the normalized basic factor. -/
def basicResidueValue587 (row : Fin 292) (j : Fin 293) : ZMod 8219 :=
  let w := embeddingRoot (p := 587) certificate587.root row ^
    conjugateExponent587 j
  w ^ 258 * basicResidueGeomSum587 row j

/-- Since `6529 = 11 * 587 + 72`, the literal source sum reduces to
length 72 at a 587th root. -/
theorem basicResidueGeomSum587_eq (row : Fin 292) (j : Fin 293) :
    basicResidueGeomSum587 row j =
      ∑ k ∈ Finset.range 72,
        (embeddingRoot (p := 587) certificate587.root row ^
          conjugateExponent587 j) ^ k := by
  let w : ZMod 8219 :=
    embeddingRoot (p := 587) certificate587.root row ^
      conjugateExponent587 j
  have hwroot : IsPrimitiveRoot w 587 := by
    apply (embeddingRoot_isPrimitive certificate587.hp2
      certificate587.root_isPrimitive row).pow_of_coprime
    exact (by norm_num : Nat.Coprime 6529 587).pow_left j.val
  have hwne : w - 1 ≠ 0 :=
    sub_ne_zero.mpr (hwroot.ne_one (by norm_num))
  apply mul_left_cancel₀ (a := w - 1) hwne
  rw [show (w - 1) * basicResidueGeomSum587 row j = w ^ 6529 - 1 by
    simpa [basicResidueGeomSum587, w] using (mul_geom_sum w 6529)]
  rw [show (w - 1) *
      (∑ k ∈ Finset.range 72,
        (embeddingRoot (p := 587) certificate587.root row ^
          conjugateExponent587 j) ^ k) = w ^ 72 - 1 by
    simpa [w] using (mul_geom_sum w 72)]
  rw [show 6529 = 587 * 11 + 72 by norm_num, pow_add, pow_mul,
    hwroot.pow_eq_one, one_pow, one_mul]

/-! ## Compact cyclic provenance

The former proof checked the edge-symbol and normalized-value identities
simultaneously in all `292 × 293` positions.  The real residue group is
cyclic of order `293`, so those checks factor through two one-variable
certificates and an algebraic phase argument. -/

/-- In the real cyclic quotient, multiplication by `72` is translation by
`80`; equivalently, `2^80 = -72 (mod 587)`. -/
theorem cycleColumn587_coord (ell : Fin 292) :
    coord (columnPermutation (cycleColumn587 ell)) =
      ((80 * (ell.val + 1) : ℕ) : Cyc) := by
  decide +revert

/-- The stored column is the canonical representative of
`72^(ell+1)` up to the harmless real-class sign. -/
theorem cycleColumn587_realRepresentative (ell : Fin 292) :
    let a := ((cycleColumn587 ell).val + 2 : ZMod 587)
    let d := (teichmullerRoot587 : ZMod 587) ^ (ell.val + 1)
    a = d ∨ a = -d := by
  decide +revert

/-- Cyclic coordinate of an original embedding row. -/
def rowCycleCoord587 (row : Fin 292) : Cyc :=
  coord (rowPermutation row)

/-- Extend the literal conjugate powers through the wrap at exponent
`293`. -/
def extendedConjugateExponent587 (ell : Fin 294) : ℕ :=
  teichmullerRoot587 ^ ell.val

/-- Its cyclic real-residue coordinate. -/
def extendedCycleCoord587 (ell : Fin 294) : Cyc :=
  ((80 * ell.val : ℕ) : Cyc)

private theorem weight_eq_of_eq_or_inv {x y : ZMod 8219}
    (hy : y ≠ 0) (h : x = y ∨ x = y⁻¹) :
    weight x = weight y := by
  rcases h with h | h
  · rw [h]
  · rw [h, weight_inv y hy]

private theorem pow_eq_inv_pow_of_cast_eq_neg
    {x : ZMod 8219} (hx : IsPrimitiveRoot x 587)
    {a b : ℕ}
    (h : (a : ZMod 587) = -(b : ZMod 587)) :
    x ^ a = (x ^ b)⁻¹ := by
  have hab : a + b ≡ 0 [MOD 587] := by
    rw [← ZMod.natCast_eq_natCast_iff]
    simpa only [Nat.cast_add, Nat.cast_zero, add_eq_zero_iff_eq_neg] using h
  have hp : x ^ (a + b) = 1 := by
    simpa using pow_eq_pow_of_modEq hab hx.pow_eq_one
  apply (mul_eq_one_iff_eq_inv₀
    (pow_ne_zero b (hx.ne_zero (by norm_num)))).mp
  rw [← pow_add]
  exact hp

private theorem pow_eq_or_inv_pow_of_cast_eq_or_neg
    {x : ZMod 8219} (hx : IsPrimitiveRoot x 587)
    {a b : ℕ}
    (h : (a : ZMod 587) = b ∨ (a : ZMod 587) = -(b : ZMod 587)) :
    x ^ a = x ^ b ∨ x ^ a = (x ^ b)⁻¹ := by
  rcases h with h | h
  · left
    apply pow_eq_pow_of_modEq _ hx.pow_eq_one
    rw [← ZMod.natCast_eq_natCast_iff]
    exact h
  · exact Or.inr (pow_eq_inv_pow_of_cast_eq_neg hx h)

/-- The weight of every conjugated root is its cyclic phase weight.  This
is parametric in the row; only the two column-orientation facts above are
checked finitely. -/
theorem extendedConjugateWeight587 (row : Fin 292) (ell : Fin 294) :
    let x := embeddingRoot (p := 587) (8165 : ZMod 8219) row
    weight (x ^ extendedConjugateExponent587 ell) =
      weight (classRoot (rowCycleCoord587 row + extendedCycleCoord587 ell)) := by
  let x := embeddingRoot (p := 587) (8165 : ZMod 8219) row
  change
    weight (x ^ extendedConjugateExponent587 ell) =
      weight (classRoot (rowCycleCoord587 row + extendedCycleCoord587 ell))
  have hxprim : IsPrimitiveRoot x 587 :=
    embeddingRoot_isPrimitive (p := 587) (q := 8219) (by norm_num)
      root_isPrimitive row
  have hx0 : x ≠ 0 := hxprim.ne_zero (by norm_num)
  by_cases hzero : ell.val = 0
  · have hell : ell = ⟨0, by norm_num⟩ := Fin.ext hzero
    subst ell
    have hrow :
        classRoot (rowCycleCoord587 row) = x ∨
          classRoot (rowCycleCoord587 row) = x⁻¹ := by
      simpa [x, rowCycleCoord587] using row_root_relation row
    have hw := weight_eq_of_eq_or_inv hx0 hrow
    simpa [x, rowCycleCoord587, extendedConjugateExponent587,
      extendedCycleCoord587] using hw.symm
  by_cases hlast : ell.val = 293
  · have hell : ell = ⟨293, by norm_num⟩ := Fin.ext hlast
    subst ell
    have hpow293 :
        x ^ extendedConjugateExponent587 ⟨293, by norm_num⟩ = x⁻¹ := by
      have hcast :
          (extendedConjugateExponent587 ⟨293, by norm_num⟩ : ZMod 587) =
            -(1 : ZMod 587) := by
        decide +kernel
      simpa only [pow_one] using
        pow_eq_inv_pow_of_cast_eq_neg hxprim hcast
    have hrow :
        classRoot (rowCycleCoord587 row) = x ∨
          classRoot (rowCycleCoord587 row) = x⁻¹ := by
      simpa [x, rowCycleCoord587] using row_root_relation row
    have hw := weight_eq_of_eq_or_inv hx0 hrow
    have hcoordlast :
        extendedCycleCoord587 ⟨293, by norm_num⟩ = 0 := by
      decide
    calc
      weight
          (x ^ extendedConjugateExponent587 ⟨293, by norm_num⟩) =
          weight x⁻¹ := congrArg weight hpow293
      _ = weight x := weight_inv x hx0
      _ = weight
          (classRoot
            (rowCycleCoord587 row +
              extendedCycleCoord587 ⟨293, by norm_num⟩)) := by
        rw [hcoordlast, add_zero]
        exact hw.symm
  · have hpos : 1 ≤ ell.val := by omega
    have hle : ell.val ≤ 292 := by omega
    let k : Fin 292 := ⟨ell.val - 1, by omega⟩
    have hk : k.val + 1 = ell.val := by simp [k]; omega
    let a := (cycleColumn587 k).val + 2
    have hrep := cycleColumn587_realRepresentative k
    have hcast :
        (a : ZMod 587) =
            (extendedConjugateExponent587 ell : ZMod 587) ∨
          (a : ZMod 587) =
            -(extendedConjugateExponent587 ell : ZMod 587) := by
      simpa [a, extendedConjugateExponent587, hk] using hrep
    have hpow := pow_eq_or_inv_pow_of_cast_eq_or_neg hxprim hcast
    have hpowWeight :
      weight (x ^ a) =
          weight (x ^ extendedConjugateExponent587 ell) :=
      weight_eq_of_eq_or_inv
        (pow_ne_zero (extendedConjugateExponent587 ell) hx0) hpow
    have hprod :
        classRoot
            (rowCycleCoord587 row +
              coord (columnPermutation (cycleColumn587 k))) =
            x ^ a ∨
          classRoot
            (rowCycleCoord587 row +
              coord (columnPermutation (cycleColumn587 k))) =
            (x ^ a)⁻¹ := by
      simpa [x, a, rowCycleCoord587] using
        product_root_relation row (cycleColumn587 k)
    have hprodWeight :
        weight
            (classRoot
              (rowCycleCoord587 row +
                coord (columnPermutation (cycleColumn587 k)))) =
          weight (x ^ a) := by
      exact weight_eq_of_eq_or_inv (pow_ne_zero a hx0) hprod
    rw [cycleColumn587_coord k] at hprodWeight
    have hcoord :
        ((80 * (k.val + 1) : ℕ) : Cyc) = extendedCycleCoord587 ell := by
      simp only [extendedCycleCoord587, hk]
    rw [hcoord] at hprodWeight
    exact (hprodWeight.trans hpowWeight).symm

private theorem normalizedGeom_pow_eq_weight_ratio
    (w : ZMod 8219) (hw : IsPrimitiveRoot w 587) (a e : ℕ)
    (hexp : 14 * e + 7 * a ≡ 7 [MOD 587]) :
    (w ^ e * ∑ k ∈ Finset.range a, w ^ k) ^ 14 =
      weight (w ^ a) / weight w := by
  have hw0 : w ≠ 0 := hw.ne_zero (by norm_num)
  have hw1 : 1 - w ≠ 0 :=
    sub_ne_zero.mpr (Ne.symm (hw.ne_one (by norm_num)))
  have hgeom :
      ∑ k ∈ Finset.range a, w ^ k = (1 - w ^ a) / (1 - w) := by
    apply (eq_div_iff hw1).2
    calc
      (∑ k ∈ Finset.range a, w ^ k) * (1 - w) =
          -((w - 1) * ∑ k ∈ Finset.range a, w ^ k) := by ring
      _ = -(w ^ a - 1) := by rw [mul_geom_sum]
      _ = 1 - w ^ a := by ring
  rw [hgeom, ← mul_div_assoc]
  change (w ^ e * (1 - w ^ a) / (1 - w)) ^ 14 =
    weight (w ^ a) / weight w
  have hpow : w ^ (14 * e + 7 * a) = w ^ 7 :=
    pow_eq_pow_of_modEq hexp hw.pow_eq_one
  simp only [weight, mul_pow, div_pow]
  field_simp [hw0, hw1]
  have hpow' : w ^ (e * 14) * w ^ (a * 7) = w ^ 7 := by
    rw [← pow_add]
    simpa [Nat.mul_comm] using hpow
  calc
    _ = (w ^ (e * 14) * w ^ (a * 7)) * (1 - w ^ a) ^ 14 := by ring
    _ = w ^ 7 * (1 - w ^ a) ^ 14 := by rw [hpow']
    _ = _ := by ring

theorem normalizedLength72_pow_eq_weight_ratio
    (w : ZMod 8219) (hw : IsPrimitiveRoot w 587) :
    (w ^ 258 * ∑ k ∈ Finset.range 72, w ^ k) ^ 14 =
      weight (w ^ 72) / weight w :=
  normalizedGeom_pow_eq_weight_ratio w hw 72 258 (by norm_num)

/-- The extended cycle symbols are ordinary differences of the compressed
phase vector. -/
theorem cycleClassSymbol587_succ_phase (row ell : Fin 292) :
    cycleClassSymbol587 row (ell.val + 1) =
      symbolPhase
          (rowCycleCoord587 row +
            ((80 * (ell.val + 1) : ℕ) : Cyc)) -
        symbolPhase (rowCycleCoord587 row) := by
  rw [cycleClassSymbol587, dif_pos]
  · change
      symbolPhase
            (coord (rowPermutation row) +
              coord (columnPermutation (cycleColumn587 ell))) -
          symbolPhase (coord (rowPermutation row)) =
        _
    rw [cycleColumn587_coord]
    rfl
  · omega

theorem cycleClassSymbol587_phase (row : Fin 292) (ell : ℕ)
    (hell : ell ≤ 293) :
    cycleClassSymbol587 row ell =
      symbolPhase
          (rowCycleCoord587 row + ((80 * ell : ℕ) : Cyc)) -
        symbolPhase (rowCycleCoord587 row) := by
  by_cases hzero : ell = 0
  · subst ell
    simp [cycleClassSymbol587]
  by_cases hlast : ell = 293
  · subst ell
    have hcoord : (((80 * 293 : ℕ) : Cyc)) = 0 := by decide
    rw [cycleClassSymbol587, dif_neg (by omega), hcoord, add_zero, sub_self]
  · have hpos : 1 ≤ ell := by omega
    have hle : ell ≤ 292 := by omega
    let k : Fin 292 := ⟨ell - 1, by omega⟩
    have hk : k.val + 1 = ell := by simp [k]; omega
    simpa only [hk] using cycleClassSymbol587_succ_phase row k

theorem basicEdgeSymbol587_phase (row : Fin 292) (j : Fin 293) :
    basicEdgeSymbol587 row j =
      symbolPhase
          ((rowCycleCoord587 row +
              extendedCycleCoord587 j.castSucc) + 80) -
        symbolPhase
          (rowCycleCoord587 row +
            extendedCycleCoord587 j.castSucc) := by
  rw [basicEdgeSymbol587,
    cycleClassSymbol587_phase row (j.val + 1) (by omega),
    cycleClassSymbol587_phase row j.val (by omega)]
  simp only [extendedCycleCoord587, Fin.val_castSucc]
  have hstep :
      rowCycleCoord587 row + ((80 * (j.val + 1) : ℕ) : Cyc) =
        (rowCycleCoord587 row + ((80 * j.val : ℕ) : Cyc)) + 80 := by
    push_cast
    ring
  rw [hstep]
  ring

theorem extendedConjugateStep587
    (x : ZMod 8219) (hx : IsPrimitiveRoot x 587) (j : Fin 293) :
    (x ^ extendedConjugateExponent587 j.castSucc) ^ 72 =
      x ^ extendedConjugateExponent587 j.succ := by
  rw [← pow_mul]
  apply pow_eq_pow_of_modEq _ hx.pow_eq_one
  change
    teichmullerRoot587 ^ j.val * 72 ≡
      teichmullerRoot587 ^ (j.val + 1) [MOD 587]
  rw [pow_succ]
  exact (by norm_num [teichmullerRoot587] :
    72 ≡ teichmullerRoot587 [MOD 587]).mul_left _

private def reducedBasicResidueValue587
    (row : Fin 292) (j : Fin 293) : ZMod 8219 :=
  let x := embeddingRoot (p := 587) (8165 : ZMod 8219) row
  let w := x ^ extendedConjugateExponent587 j.castSucc
  w ^ 258 * ∑ k ∈ Finset.range 72, w ^ k

private theorem reducedBasicResidueValue587_symbol
    (row : Fin 292) (j : Fin 293) :
    reducedBasicResidueValue587 row j ^ 14 =
      (8165 : ZMod 8219) ^ (basicEdgeSymbol587 row j).val := by
  let x := embeddingRoot (p := 587) (8165 : ZMod 8219) row
  let w := x ^ extendedConjugateExponent587 j.castSucc
  have hxprim : IsPrimitiveRoot x 587 :=
    embeddingRoot_isPrimitive (p := 587) (q := 8219) (by norm_num)
      root_isPrimitive row
  have hwprim : IsPrimitiveRoot w 587 := by
    apply hxprim.pow_of_coprime
    exact (by norm_num : Nat.Coprime 6529 587).pow_left j.val
  change (w ^ 258 * ∑ k ∈ Finset.range 72, w ^ k) ^ 14 = _
  rw [normalizedLength72_pow_eq_weight_ratio w hwprim]
  have hcur :
      weight w =
        weight
          (classRoot
            (rowCycleCoord587 row +
              extendedCycleCoord587 j.castSucc)) := by
    simpa [x, w] using extendedConjugateWeight587 row j.castSucc
  have hnext :
      weight (x ^ extendedConjugateExponent587 j.succ) =
        weight
          (classRoot
            (rowCycleCoord587 row +
              extendedCycleCoord587 j.succ)) := by
    simpa [x] using extendedConjugateWeight587 row j.succ
  have hstep := extendedConjugateStep587 x hxprim j
  rw [hstep, hnext, hcur]
  have hcoord :
      rowCycleCoord587 row + extendedCycleCoord587 j.succ =
        (rowCycleCoord587 row +
          extendedCycleCoord587 j.castSucc) + 80 := by
    simp only [extendedCycleCoord587, Fin.val_succ, Fin.val_castSucc]
    push_cast
    ring
  rw [hcoord, weight_ratio_eq_phase_ratio,
    phase_value_certificate, phase_value_certificate,
    ← root_pow_sub_val]
  rw [basicEdgeSymbol587_phase]

/-- Complete provenance of every basic-factor residue symbol, derived from
the one-variable cyclic certificates rather than a Cartesian case split. -/
theorem basicResidueValue587_symbol (row : Fin 292) (j : Fin 293) :
    basicResidueValue587 row j ^ 14 =
      certificate587.root ^ (basicEdgeSymbol587 row j).val := by
  rw [basicResidueValue587, basicResidueGeomSum587_eq]
  simpa [reducedBasicResidueValue587, extendedConjugateExponent587,
    conjugateExponent587, certificate587,
    Fermat.FiveHundredEightySeven.CircularUnitResidues.certificate] using
    reducedBasicResidueValue587_symbol row j

end Fermat.FiveHundredEightySeven.VandiverDiagonalUnitResidues
