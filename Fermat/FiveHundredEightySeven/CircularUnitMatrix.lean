private def rowExponentIndex (i : Fin 292) : Fin 292 :=
  ⟨rowExponentIndexNat i.val, by decide +revert⟩

private def rowIndexAtExponent (i : Fin 292) : Fin 292 :=
  ⟨rowIndexAtExponentNat i.val, by decide +revert⟩

private def columnExponentIndex (i : Fin 292) : Fin 292 :=
  ⟨columnExponentIndexNat i.val, by decide +revert⟩

private def columnIndexAtExponent (i : Fin 292) : Fin 292 :=
  ⟨columnIndexAtExponentNat i.val, by decide +revert⟩

/-- Original embedding rows `j = 1,…,292`, reordered as
`[293]·[2]^r`, `r = 1,…,292`, in `(Z/587Z)ˣ/{±1}`. -/
def rowPermutation : Equiv.Perm (Fin 292) where
  toFun := rowExponentIndex
  invFun := rowIndexAtExponent
  left_inv i := by decide +revert
  right_inv i := by decide +revert

/-- Original circular-unit columns `a = 2,…,293`, reordered as
`[2]^s`, `s = 1,…,292`, in `(Z/587Z)ˣ/{±1}`. -/
def columnPermutation : Equiv.Perm (Fin 292) where
  toFun := columnExponentIndex
  invFun := columnIndexAtExponent
  left_inv i := by decide +revert
  right_inv i := by decide +revert

/-- The package matrix, reconstructed from 293 phase values and two finite
permutations.  In cyclic coordinates it is `differenceMatrix symbolPhase`. -/
def matrix : Matrix (Fin 292) (Fin 292) (ZMod 587) :=
  Matrix.reindex rowPermutation.symm columnPermutation.symm
    (differenceMatrix symbolPhase)

end

end Fermat.FiveHundredEightySeven.CircularUnitMatrix
